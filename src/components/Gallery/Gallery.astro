---
import { Picture } from "astro:assets";
import { getLocaleFromUrl } from "@js/localeUtils";
import { useTranslations } from "@js/translationUtils";
import atlantisSteam from "@assets/images/eko-ciscenje/EV-ATLANTIS-steam-cleaner.jpeg";
import atlasCleaner from "@assets/images/eko-ciscenje/EV-ATLAS-cleaner.jpeg";
import poseidonChemical from "@assets/images/eko-ciscenje/EV-POSEIDON-chemical-cleaner.jpeg";
import threeCleaners from "@assets/images/eko-ciscenje/Three-EV-cleaners-variants.jpeg";
import visualAtlantis from "@assets/images/eko-ciscenje/Beautifully-designed-visual-EV-Atlantis.jpg";

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
---

<!-- ============================================ -->
<!--                   Gallery                    -->
<!-- ============================================ -->

<section id="gallery">
	<div class="cs-container">
		<span class="cs-topper">{t("home:portfolio.topper")}</span>
		<h2 class="cs-title">
			{t("home:portfolio.title")}
		</h2>
		<div class="cs-image-group">
			<!-- Row 1-->
			<div class="cs-row cs-row-1">
				<!-- To add more images, copy and paste this row's picture tags here in order from cs-picture-1 to cs-picture-3 and they will maintain the same layout-->
				<Picture src={atlantisSteam} alt="Steam cleaning machine in action" width={400} formats={["avif", "webp"]} pictureAttributes={{ class: "cs-picture cs-picture1" }} aria-hidden="true" decoding="async" loading="lazy" />
				<Picture src={atlasCleaner} alt="Industrial eco-cleaning equipment" width={400} formats={["avif", "webp"]} pictureAttributes={{ class: "cs-picture cs-picture2" }} aria-hidden="true" decoding="async" loading="lazy" />
				<Picture src={poseidonChemical} alt="Steam cleaning unit with eco packaging" width={400} formats={["avif", "webp"]} pictureAttributes={{ class: "cs-picture cs-picture3" }} aria-hidden="true" decoding="async" loading="lazy" />
			</div>
			<!-- Row 2 -->
			<div class="cs-row cs-row-2">
				<!-- To add more images, copy and paste this row's picture tags here in order from cs-picture-1 to cs-picture-3 and they will maintain the same layout-->
				<Picture src={visualAtlantis} alt="Eco cleaning brand visual" width={400} formats={["avif", "webp"]} pictureAttributes={{ class: "cs-picture cs-picture1" }} aria-hidden="true" decoding="async" loading="lazy" />
				<Picture src={threeCleaners} alt="Three eco cleaning machines" width={400} formats={["avif", "webp"]} pictureAttributes={{ class: "cs-picture cs-picture2" }} aria-hidden="true" decoding="async" loading="lazy" />
				<Picture src={atlantisSteam} alt="Steam cleaning machine in action" width={400} formats={["avif", "webp"]} pictureAttributes={{ class: "cs-picture cs-picture3" }} aria-hidden="true" decoding="async" loading="lazy" />
			</div>
			<!-- Row 3 -->
			<div class="cs-row cs-row-3">
				<!-- To add more images, copy and paste this row's picture tags here in order from cs-picture-1 to cs-picture-3 and they will maintain the same layout-->
				<Picture src={atlasCleaner} alt="Industrial eco-cleaning equipment" width={400} formats={["avif", "webp"]} pictureAttributes={{ class: "cs-picture cs-picture1" }} aria-hidden="true" decoding="async" loading="lazy" />
				<Picture src={poseidonChemical} alt="Steam cleaning unit with eco packaging" width={400} formats={["avif", "webp"]} pictureAttributes={{ class: "cs-picture cs-picture2" }} aria-hidden="true" decoding="async" loading="lazy" />
				<Picture src={visualAtlantis} alt="Eco cleaning brand visual" width={400} formats={["avif", "webp"]} pictureAttributes={{ class: "cs-picture cs-picture3" }} aria-hidden="true" decoding="async" loading="lazy" />
			</div>
		</div>
	</div>
</section>

<style lang="less">
	/*-- -------------------------- -->
<---          Gallery           -->
<--- -------------------------- -*/

	/* Mobile - 360px - Contains hover animation */
	@media only screen and (min-width: 0em) {
		#gallery {
			/* Centers button */
			text-align: center;
			padding: var(--sectionPadding);
			position: relative;
			/* Prevents overflow from the image going off screen */
			overflow: hidden;
			.cs-container {
				width: 100%;
				max-width: (1322/16em);
				margin: auto;
			}

			.cs-topper {
				text-align: center;
				margin-bottom: (16/16rem);
			}

			.cs-title {
				text-align: center;
				max-width: (621/16rem);
				margin-bottom: (40/16rem);
			}

			.cs-image-group {
				/* used rem so it doesn't scale with the font size of on parent */
				font-size: ~"min(1.1vw, 1em)";
				width: 100%;
				max-width: (1322/16em);
				margin: 0 auto (60/16rem);
				padding: 0;
				display: flex;
				justify-content: center;
				align-items: flex-start;
				gap: (30/16em);
			}

			.cs-row {
				display: flex;
				flex-direction: column;
				justify-content: flex-start;
				align-items: center;
				gap: (30/16em);
			}

			.cs-picture {
				display: block;
				position: relative;
				img {
					width: 100%;
					height: 100%;
					object-fit: cover;
					position: absolute;
					top: 0;
					left: 0;
				}
			}

			.cs-row-1 {
				.cs-picture1 {
					width: (420/16em);
					height: (567/16em);
				}

				.cs-picture2 {
					width: (420/16em);
					height: (629/16em);
				}

				.cs-picture3 {
					width: (420/16em);
					height: (512/16em);
				}
			}

			.cs-row-2 {
				.cs-picture1 {
					width: (420/16em);
					height: (492/16em);
				}

				.cs-picture2 {
					width: (420/16em);
					height: (517/16em);
				}

				.cs-picture3 {
					width: (420/16em);
					height: (629/16em);
				}
			}

			.cs-row-3 {
				.cs-picture1 {
					width: (420/16em);
					height: (625/16em);
				}

				.cs-picture2 {
					width: (420/16em);
					height: (452/16em);
				}

				.cs-picture3 {
					width: (420/16em);
					height: (629/16em);
				}
			}
		}
	}

	/* Dark mode */
	@media only screen and (min-width: 0em) {
		body.dark-mode {
			#gallery {
				.cs-title {
					color: var(--bodyTextColorWhite);
				}
			}
		}
	}
</style>
