---
import BaseLayout from "@layouts/BaseLayout.astro";
import CTA from "@components/CTA/CTA.astro";
import Banner from "@components/Banner/Banner.astro";
import MenuSection from "@components/Menu/MenuSection.astro";
import { getLocaleFromUrl } from "@js/localeUtils";
import { useTranslations } from "@js/translationUtils";
import landingImage from "@assets/images/food/two-burgers.jpg";
import { getAstroPieMenuData, getMenuPageCategoryIds } from "../../../googleSheets";

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const menuData = await getAstroPieMenuData();
const categoryIds = getMenuPageCategoryIds(menuData, "grill");
---

<BaseLayout title={t("project-1")} description={t("home:extra.p1")}>
	<Banner title={t("project-1")} image={landingImage} />
	<MenuSection
		locale={locale}
		categoryIds={categoryIds}
		menuData={menuData}
		intro={t("home:extra.p1")}
	/>
	<CTA />
</BaseLayout>
